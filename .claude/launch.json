{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Server (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "--listen", "3000", "."],
      "port": 3000
    },
    {
      "name": "Live Server (live-reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8080", "."],
      "port": 8080
    }
  ]
}
